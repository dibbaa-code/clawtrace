# Add your environment variables here
# Copy this file to .env.local and fill in your values

# Clawdbot gateway auth token
CLAWDBOT_API_TOKEN=
# Clawdbot gateway URL (format: ws://127.0.0.1:<port of clawdbot>)
CLAWDBOT_URL=


# Threat detection (LLM) - optional; enables malicious event classification
OPENAI_API_KEY=

# Discord alerts - optional; webhook URL for malicious event notifications
DISCORD_WEBHOOK_URL=

# Base URL for dashboard links in alerts (default: http://localhost:3000)
CLAWTRACE_BASE_URL=

