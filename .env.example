# Add your environment variables here
# Copy this file to .env.local and fill in your values

# Clawdbot gateway auth token
CLAWDBOT_API_TOKEN=

# Threat detection (LLM) - required for event analysis
OPENAI_API_KEY= 

# Discord alerts - webhook URL for malicious event notifications
DISCORD_WEBHOOK_URL=

# Base URL for dashboard links in alerts (default: http://localhost:3000)
CLAWTRACE_BASE_URL=

